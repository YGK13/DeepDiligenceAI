# ============================================================================
# DeepDiligence AI — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# MODES:
#   - LOCAL MODE:  Leave Supabase vars empty → app runs on localStorage only
#   - CLOUD MODE:  Fill in Supabase vars → auth + cloud persistence enabled
#
# AI KEYS:
#   - Server env vars take priority over client-side keys in Settings
#   - You can also enter API keys in the Settings UI (stored in localStorage)
#   - At minimum, configure ONE provider to use AI Research
# ============================================================================

# ============================================================================
# Supabase — Auth & Database (optional for local dev, required for production)
# ============================================================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# URL = Project URL (e.g., https://xxxxx.supabase.co)
# ANON KEY = public anon key (safe for browser, protected by RLS)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================================
# AI Provider API Keys (server-side only — NEVER exposed to the browser)
# ============================================================================

# Perplexity AI — RECOMMENDED for due diligence (includes real-time web search)
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Anthropic (Claude) — Best for deep analytical reasoning
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o) — Strong general-purpose analysis
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (Llama) — Ultra-fast inference, good for rapid iteration
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=
